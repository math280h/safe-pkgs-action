{
  "name": "safe-pkgs-action",
  "version": "1.0.0",
  "description": "GitHub Action to audit dependencies with safe-pkgs",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outfile=dist/index.js --target=node --minify",
    "test": "bun test",
    "check": "biome check src tests",
    "check:fix": "biome check --write src tests"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
